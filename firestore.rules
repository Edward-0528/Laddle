rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // quizzes collection
    // -----------------------------------------------------------------------
    match /quizzes/{quizId} {

      // LIST queries for library templates — anyone (including unauthenticated).
      // Firestore evaluates list rules at collection level (no resource.data),
      // so we need a broad allow list here and rely on query constraints
      // (isTemplate==true, createdBy=='SYSTEM') to scope results server-side.
      allow list: if true;

      // GET (single document read) — public for SYSTEM templates,
      // private for user-owned quizzes.
      allow get: if resource.data.isTemplate == true
                    && resource.data.createdBy == 'SYSTEM';

      allow get: if request.auth != null
                    && resource.data.createdBy == request.auth.uid;

      // CREATE — any signed-in user can create their own quizzes (forks).
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.isTemplate == false;

      // Seed CREATE — any signed-in user can write SYSTEM templates.
      // This allows the in-browser seedLibrary() call to work.
      allow create: if request.auth != null
                    && request.resource.data.createdBy == 'SYSTEM'
                    && request.resource.data.isTemplate == true;

      // UPDATE / DELETE — users can only modify their own quizzes.
      allow update, delete: if request.auth != null
                             && resource.data.createdBy == request.auth.uid;

      // SYSTEM template stat increment (used by forkQuizToUser counter).
      allow update: if request.auth != null
                    && resource.data.createdBy == 'SYSTEM'
                    && resource.data.isTemplate == true
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['stats']);
    }
  }
}
