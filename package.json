{
  "name": "laddle",
  "version": "1.0.0",
  "description": "Real-time quiz game similar to Kahoot",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -b && vite build",
    "build:server": "cd server && npm run build",
    "start": "cd server && npm start",
    "install:all": "npm install && cd server && npm install",
    "preview": "vite preview",
    "lint:emoji": "bash scripts/check-no-emoji.sh",
    "prepare": "husky"
  },
  "keywords": [
    "quiz",
    "game",
    "kahoot",
    "education",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "~5.8.3",
    "vite": "^7.1.2"
  },
  "dependencies": {
    "@e965/xlsx": "^0.20.3",
    "@tanstack/react-query": "^5.100.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "firebase": "^12.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.0",
    "socket.io-client": "^4.8.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,css}": [],
    "server/src/**/*.{ts}": []
  }
}
